// ============================================================
// GLOBAL PRODUCTION WORKFLOW
// ============================================================

// ONE ordered list of production steps every job order moves through (ruling
// 2026-07-24: a single global workflow replaces the per-product ProductionStep
// templates). Steps are ranked FROM THE END: rankFromEnd 1 = the LAST step
// (e.g. "DR"), 2 = second-to-last ("Capture"), … — the shop defines the flow
// backward from delivery. Workflow order = rankFromEnd DESC (highest first,
// rank 1 last). Copied onto JobOrderItemStep when a JO item is created.
model GlobalProductionStep {
  id          String   @id @default(cuid())
  name        String
  rankFromEnd Int // 1 = last step, 2 = 2nd-to-last, …
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
